            "name": "Cancelar Reserva (Protegido)",
            "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                    "raw": "http://localhost:8000/reservas/{{reserva_id}}",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "reservas",
                        "{{reserva_id}}"
                    ]
                },
                "auth": {
                    "type": "basic",
                    "basic": [
                        {
                            "key": "password",
                            "value": "rest123",

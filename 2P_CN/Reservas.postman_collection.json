                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "reservas"
                    ]
                },
                "auth": {
                    "type": "basic",
                    "basic": [
                        {
                            "key": "password",
                            "value": "rest123",
                            "type": "string"
                        },
                        {
                            "key": "username",
                            "value": "admin",
                            "type": "string"
                        }
                    ]
                }
            },
            "response": []
        },

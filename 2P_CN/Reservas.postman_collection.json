            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"cliente_nombre\": \"Juan Perez\",\n    \"fecha_reserva\": \"2026-10-15 10:30\",\n    \"numero_personas\": 4\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/reservas",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "reservas"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "Consultar por ID",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://localhost:8000/reservas/{{reserva_id}}",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "reservas",
                        "{{reserva_id}}"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "Confirmar Reserva",
            "request": {
                "method": "PATCH",
                "header": [],
                "url": {
                    "raw": "http://localhost:8000/reservas/{{reserva_id}}/confirmar",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "reservas",
                        "{{reserva_id}}",
                        "confirmar"
                    ]
                }
            },
            "response": []
        },
        {

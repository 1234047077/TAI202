            "request": {
                "method": "PUT",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"cliente_nombre\": \"Juan Perez Actualizado\",\n    \"fecha_reserva\": \"2026-10-15 12:30\",\n    \"numero_personas\": 5\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/reservas/{{reserva_id}}",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "reservas",
                        "{{reserva_id}}"
                    ]
                }
            },
            "response": []
        },
